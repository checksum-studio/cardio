{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cardio",
  "version": "0.2.0",
  "identifier": "space.checksum.cardio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cardio",
        "width": 500,
        "height": 500,
        "minWidth": 500,
        "minHeight": 500,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "bluez"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENFQjkyQkI0MDcxRDJBMTgKUldRWUtoMEh0Q3U1enRBWEUramlFSkNvcjZ6TkFkT3dnUU5MWlZaUHdwelpIUE53Q1BJanZLMTEK",
      "endpoints": [
        "https://github.com/checksum-studio/cardio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
